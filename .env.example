# Supabase — get from supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — required for npm run setup:avatars (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — auto-applies avatar storage policies via npm run setup:avatars
# Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Groq — get from console.groq.com (free)
GROQ_API_KEY=gsk_your-groq-api-key

# App URL (use https://your-app.vercel.app in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email invites (optional — get from resend.com)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=CodeMedic AI <onboarding@yourdomain.com>
